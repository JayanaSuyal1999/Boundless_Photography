# ─── Boundless Moments — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values before running the app.

# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-very-secret-key-change-in-production

# PostgreSQL  — update host/user/password/dbname to match your setup
DATABASE_URL=postgresql://postgres:Megamind@localhost:5432/boundless_moments

# Admin credentials (stored in DB — these seed the first admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
